{
  "name": "CentOS 安全基线",
  "version": "1.0.0",
  "description": "CentOS操作系统安全基线检查",
  "compliance": ["等保2.0", "CIS"],
  "rules": [
    {
      "id": "CENTOS-001",
      "name": "密码最大有效期",
      "description": "检查密码最大使用天数",
      "command": "grep 'PASS_MAX_DAYS' /etc/login.defs | awk '{print $2}'",
      "expected": "90",
      "check_type": "equals",
      "severity": "high",
      "category": "账户安全"
    },
    {
      "id": "CENTOS-002",
      "name": "密码最小长度",
      "description": "检查密码最小长度",
      "command": "grep 'PASS_MIN_LEN' /etc/login.defs | awk '{print $2}'",
      "expected": "8",
      "check_type": "contains",
      "severity": "high",
      "category": "账户安全"
    },
    {
      "id": "CENTOS-003",
      "name": "禁止root远程登录",
      "description": "检查是否禁止root远程SSH登录",
      "command": "grep '^PermitRootLogin' /etc/ssh/sshd_config",
      "expected": "PermitRootLogin no",
      "check_type": "contains",
      "severity": "high",
      "category": "访问控制"
    },
    {
      "id": "CENTOS-004",
      "name": "防火墙状态",
      "description": "检查firewalld状态",
      "command": "systemctl is-active firewalld 2>/dev/null || systemctl is-active iptables 2>/dev/null",
      "expected": "active",
      "check_type": "contains",
      "severity": "high",
      "category": "边界防护"
    },
    {
      "id": "CENTOS-005",
      "name": "SELinux状态",
      "description": "检查SELinux是否启用",
      "command": "getenforce 2>/dev/null || cat /etc/selinux/config | grep '^SELINUX='",
      "expected": "Enforcing",
      "check_type": "contains",
      "severity": "high",
      "category": "安全加固"
    },
    {
      "id": "CENTOS-006",
      "name": "审计服务状态",
      "description": "检查auditd服务状态",
      "command": "systemctl is-active auditd",
      "expected": "active",
      "check_type": "contains",
      "severity": "high",
      "category": "审计日志"
    },
    {
      "id": "CENTOS-007",
      "name": "空密码账户检查",
      "description": "检查是否存在空密码账户",
      "command": "awk -F: '($2 == \"\") {print $1}' /etc/shadow",
      "expected": "",
      "check_type": "equals",
      "severity": "high",
      "category": "账户安全"
    },
    {
      "id": "CENTOS-008",
      "name": "UID为0的账户",
      "description": "检查UID为0的账户",
      "command": "awk -F: '($3 == 0) {print $1}' /etc/passwd",
      "expected": "root",
      "check_type": "equals",
      "severity": "high",
      "category": "账户安全"
    },
    {
      "id": "CENTOS-009",
      "name": "SSH协议版本",
      "description": "检查SSH协议版本",
      "command": "grep '^Protocol' /etc/ssh/sshd_config || echo 'Protocol 2'",
      "expected": "2",
      "check_type": "contains",
      "severity": "medium",
      "category": "通信安全"
    },
    {
      "id": "CENTOS-010",
      "name": "yum GPG检查",
      "description": "检查yum GPG检查是否启用",
      "command": "grep 'gpgcheck' /etc/yum.conf",
      "expected": "gpgcheck=1",
      "check_type": "contains",
      "severity": "medium",
      "category": "软件安全"
    },
    {
      "id": "CENTOS-011",
      "name": "不必要服务-telnet",
      "description": "检查telnet服务",
      "command": "systemctl is-active telnet.socket 2>/dev/null || echo '未安装'",
      "expected": "未安装",
      "check_type": "contains",
      "severity": "high",
      "category": "服务安全"
    },
    {
      "id": "CENTOS-012",
      "name": "不必要服务-FTP",
      "description": "检查FTP服务",
      "command": "systemctl is-active vsftpd 2>/dev/null || echo '未安装'",
      "expected": "未安装",
      "check_type": "contains",
      "severity": "medium",
      "category": "服务安全"
    },
    {
      "id": "CENTOS-013",
      "name": "登录失败锁定",
      "description": "检查登录失败锁定策略",
      "command": "grep 'pam_faillock' /etc/pam.d/system-auth /etc/pam.d/password-auth 2>/dev/null",
      "expected": "pam_faillock",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别"
    },
    {
      "id": "CENTOS-014",
      "name": "密码复杂度",
      "description": "检查密码复杂度要求",
      "command": "grep -E 'minlen|minclass' /etc/security/pwquality.conf 2>/dev/null",
      "expected": "minlen",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别"
    },
    {
      "id": "CENTOS-015",
      "name": "SSH MaxAuthTries",
      "description": "检查SSH最大认证尝试次数",
      "command": "grep 'MaxAuthTries' /etc/ssh/sshd_config",
      "expected": "MaxAuthTries",
      "check_type": "contains",
      "severity": "medium",
      "category": "访问控制"
    }
  ]
}
