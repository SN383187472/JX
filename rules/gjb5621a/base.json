{
  "name": "GJB 5621A 军用软件安全基线",
  "version": "1.0.0",
  "description": "符合GJB 5621A-2017军用软件安全需求分析指南的安全基线检查",
  "compliance": ["GJB 5621A-2017"],
  "category": "军用软件安全",
  "rules": [
    {
      "id": "GJB-5621A-001",
      "name": "保密性-密码存储加密",
      "description": "检查用户密码是否使用强加密存储",
      "command": "grep -E '^ENCRYPT_METHOD|^SHA_CRYPT' /etc/login.defs",
      "expected": "SHA512",
      "check_type": "contains",
      "severity": "high",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-5621A-002",
      "name": "保密性-敏感文件权限",
      "description": "检查shadow文件权限",
      "command": "stat -c '%a' /etc/shadow",
      "expected": "0",
      "check_type": "contains",
      "severity": "high",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-5621A-003",
      "name": "保密性-SSH加密算法",
      "description": "检查SSH是否使用强加密算法",
      "command": "grep 'Ciphers' /etc/ssh/sshd_config",
      "expected": "aes256",
      "check_type": "contains",
      "severity": "high",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-5621A-004",
      "name": "保密性-屏幕自动锁定",
      "description": "检查是否配置自动锁屏",
      "command": "gsettings get org.gnome.desktop.screensaver lock-enabled 2>/dev/null || echo '需配置'",
      "expected": "true",
      "check_type": "contains",
      "severity": "medium",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-5621A-005",
      "name": "完整性-文件完整性监控",
      "description": "检查是否部署文件完整性监控工具",
      "command": "which aide 2>/dev/null || which tripwire 2>/dev/null || echo '未部署'",
      "expected": "aide",
      "check_type": "contains",
      "severity": "high",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-5621A-006",
      "name": "完整性-系统文件校验",
      "description": "检查关键系统文件完整性",
      "command": "rpm -Va 2>/dev/null | head -10 || dpkg --verify 2>/dev/null | head -10",
      "expected": "",
      "check_type": "equals",
      "severity": "high",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-5621A-007",
      "name": "完整性-软件包签名验证",
      "description": "检查是否启用软件包签名验证",
      "command": "grep 'gpgcheck' /etc/yum.conf 2>/dev/null || grep 'AllowUnauthenticated' /etc/apt/apt.conf.d/* 2>/dev/null",
      "expected": "gpgcheck=1",
      "check_type": "contains",
      "severity": "medium",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-5621A-008",
      "name": "可用性-系统备份",
      "description": "检查是否配置系统备份",
      "command": "ls -la /var/backups/ 2>/dev/null || ls -la /backup/ 2>/dev/null || echo '需配置备份'",
      "expected": "",
      "check_type": "not_empty",
      "severity": "high",
      "category": "可用性",
      "compliance": "GJB 5621A-2017-可用性"
    },
    {
      "id": "GJB-5621A-009",
      "name": "可用性-磁盘空间监控",
      "description": "检查磁盘空间使用率",
      "command": "df -h | awk 'NR>1 {print $5}' | grep -o '[0-9]*' | sort -rn | head -1",
      "expected": "90",
      "check_type": "contains",
      "severity": "medium",
      "category": "可用性",
      "compliance": "GJB 5621A-2017-可用性"
    },
    {
      "id": "GJB-5621A-010",
      "name": "可用性-资源限制",
      "description": "检查系统资源限制配置",
      "command": "cat /etc/security/limits.conf | grep -v '^#' | grep -v '^$' | head -10",
      "expected": "",
      "check_type": "not_empty",
      "severity": "medium",
      "category": "可用性",
      "compliance": "GJB 5621A-2017-可用性"
    },
    {
      "id": "GJB-5621A-011",
      "name": "不可否认-审计服务",
      "description": "检查审计服务是否启用",
      "command": "systemctl is-active auditd 2>/dev/null || echo 'inactive'",
      "expected": "active",
      "check_type": "contains",
      "severity": "high",
      "category": "不可否认性",
      "compliance": "GJB 5621A-2017-不可否认性"
    },
    {
      "id": "GJB-5621A-012",
      "name": "不可否认-审计规则",
      "description": "检查审计规则配置",
      "command": "auditctl -l 2>/dev/null | wc -l",
      "expected": "1",
      "check_type": "not_empty",
      "severity": "high",
      "category": "不可否认性",
      "compliance": "GJB 5621A-2017-不可否认性"
    },
    {
      "id": "GJB-5621A-013",
      "name": "不可否认-日志远程传输",
      "description": "检查日志远程传输配置",
      "command": "grep '@' /etc/rsyslog.conf 2>/dev/null || echo '未配置'",
      "expected": "@",
      "check_type": "contains",
      "severity": "high",
      "category": "不可否认性",
      "compliance": "GJB 5621A-2017-不可否认性"
    },
    {
      "id": "GJB-5621A-014",
      "name": "不可否认-操作日志记录",
      "description": "检查命令操作日志记录",
      "command": "grep 'HISTTIMEFORMAT' /etc/profile 2>/dev/null || echo '需配置'",
      "expected": "HISTTIMEFORMAT",
      "check_type": "contains",
      "severity": "medium",
      "category": "不可否认性",
      "compliance": "GJB 5621A-2017-不可否认性"
    },
    {
      "id": "GJB-5621A-015",
      "name": "身份认证-密码复杂度",
      "description": "检查密码复杂度策略",
      "command": "grep -E 'minlen|minclass' /etc/security/pwquality.conf 2>/dev/null",
      "expected": "minlen",
      "check_type": "contains",
      "severity": "high",
      "category": "身份认证",
      "compliance": "GJB 5621A-2017-身份认证"
    },
    {
      "id": "GJB-5621A-016",
      "name": "身份认证-密码有效期",
      "description": "检查密码有效期设置",
      "command": "grep 'PASS_MAX_DAYS' /etc/login.defs",
      "expected": "90",
      "check_type": "contains",
      "severity": "high",
      "category": "身份认证",
      "compliance": "GJB 5621A-2017-身份认证"
    },
    {
      "id": "GJB-5621A-017",
      "name": "身份认证-登录失败锁定",
      "description": "检查登录失败锁定策略",
      "command": "grep -E 'deny=|unlock_time=' /etc/pam.d/system-auth /etc/pam.d/password-auth 2>/dev/null",
      "expected": "deny=",
      "check_type": "contains",
      "severity": "high",
      "category": "身份认证",
      "compliance": "GJB 5621A-2017-身份认证"
    },
    {
      "id": "GJB-5621A-018",
      "name": "身份认证-会话超时",
      "description": "检查会话超时设置",
      "command": "grep 'TMOUT' /etc/profile 2>/dev/null || grep 'ClientAliveInterval' /etc/ssh/sshd_config 2>/dev/null",
      "expected": "TMOUT",
      "check_type": "contains",
      "severity": "medium",
      "category": "身份认证",
      "compliance": "GJB 5621A-2017-身份认证"
    },
    {
      "id": "GJB-5621A-019",
      "name": "访问控制-特权账户",
      "description": "检查特权账户数量",
      "command": "awk -F: '$3==0 {print $1}' /etc/passwd",
      "expected": "root",
      "check_type": "equals",
      "severity": "high",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-5621A-020",
      "name": "访问控制-root远程登录",
      "description": "检查是否禁止root远程登录",
      "command": "grep 'PermitRootLogin' /etc/ssh/sshd_config",
      "expected": "PermitRootLogin no",
      "check_type": "contains",
      "severity": "high",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-5621A-021",
      "name": "访问控制-空密码账户",
      "description": "检查空密码账户",
      "command": "awk -F: '$2==\"\" {print $1}' /etc/shadow 2>/dev/null",
      "expected": "",
      "check_type": "equals",
      "severity": "high",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-5621A-022",
      "name": "访问控制-sudo权限",
      "description": "检查sudo权限配置",
      "command": "cat /etc/sudoers 2>/dev/null | grep -v '^#' | grep -v '^$'",
      "expected": "",
      "check_type": "not_empty",
      "severity": "medium",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-5621A-023",
      "name": "安全管理-补丁更新",
      "description": "检查系统版本和补丁状态",
      "command": "cat /etc/os-release | grep VERSION_ID && uname -r",
      "expected": "VERSION_ID",
      "check_type": "contains",
      "severity": "medium",
      "category": "安全管理",
      "compliance": "GJB 5621A-2017-安全管理"
    },
    {
      "id": "GJB-5621A-024",
      "name": "安全管理-服务最小化",
      "description": "检查运行服务数量",
      "command": "systemctl list-units --type=service --state=running | wc -l",
      "expected": "",
      "check_type": "not_empty",
      "severity": "low",
      "category": "安全管理",
      "compliance": "GJB 5621A-2017-安全管理"
    },
    {
      "id": "GJB-5621A-025",
      "name": "安全管理-端口最小化",
      "description": "检查开放端口数量",
      "command": "netstat -tuln | grep LISTEN | wc -l",
      "expected": "",
      "check_type": "not_empty",
      "severity": "medium",
      "category": "安全管理",
      "compliance": "GJB 5621A-2017-安全管理"
    },
    {
      "id": "GJB-5621A-026",
      "name": "边界防护-防火墙",
      "description": "检查防火墙状态",
      "command": "systemctl is-active firewalld 2>/dev/null || systemctl is-active iptables 2>/dev/null || echo 'inactive'",
      "expected": "active",
      "check_type": "contains",
      "severity": "high",
      "category": "边界防护",
      "compliance": "GJB 5621A-2017-边界防护"
    },
    {
      "id": "GJB-5621A-027",
      "name": "边界防护-危险服务",
      "description": "检查危险服务状态",
      "command": "netstat -tuln | grep -E ':23|:21|:111|:512|:513|:514'",
      "expected": "",
      "check_type": "equals",
      "severity": "high",
      "category": "边界防护",
      "compliance": "GJB 5621A-2017-边界防护"
    },
    {
      "id": "GJB-5621A-028",
      "name": "边界防护-防火墙规则",
      "description": "检查防火墙规则配置",
      "command": "iptables -L -n 2>/dev/null | head -20 || firewall-cmd --list-all 2>/dev/null",
      "expected": "",
      "check_type": "not_empty",
      "severity": "medium",
      "category": "边界防护",
      "compliance": "GJB 5621A-2017-边界防护"
    },
    {
      "id": "GJB-5621A-029",
      "name": "恶意代码防范-杀毒软件",
      "description": "检查是否安装杀毒软件",
      "command": "which clamscan 2>/dev/null || which freshclam 2>/dev/null || echo '建议安装'",
      "expected": "",
      "check_type": "not_empty",
      "severity": "high",
      "category": "恶意代码防范",
      "compliance": "GJB 5621A-2017-恶意代码防范"
    },
    {
      "id": "GJB-5621A-030",
      "name": "入侵检测-HIDS",
      "description": "检查主机入侵检测系统",
      "command": "which ossec-agentd 2>/dev/null || which wazuh-agent 2>/dev/null || systemctl is-active wazuh-agent 2>/dev/null || echo '建议部署'",
      "expected": "",
      "check_type": "not_empty",
      "severity": "high",
      "category": "入侵检测",
      "compliance": "GJB 5621A-2017-入侵检测"
    },
    {
      "id": "GJB-5621A-031",
      "name": "数据安全-磁盘加密",
      "description": "检查磁盘加密状态",
      "command": "lsblk -f 2>/dev/null | grep -E 'crypto|LUKS' || cat /etc/crypttab 2>/dev/null || echo '建议启用'",
      "expected": "",
      "check_type": "not_empty",
      "severity": "medium",
      "category": "数据安全",
      "compliance": "GJB 5621A-2017-数据安全"
    },
    {
      "id": "GJB-5621A-032",
      "name": "账户管理-默认账户处理",
      "description": "检查默认账户状态",
      "command": "cat /etc/passwd | grep -E '/bin/bash|/bin/sh' | cut -d: -f1",
      "expected": "root",
      "check_type": "contains",
      "severity": "medium",
      "category": "账户管理",
      "compliance": "GJB 5621A-2017-账户管理"
    },
    {
      "id": "GJB-5621A-033",
      "name": "网络安全-SSH版本",
      "description": "检查SSH版本",
      "command": "sshd -V 2>&1 | head -1 || rpm -qa openssh 2>/dev/null",
      "expected": "OpenSSH",
      "check_type": "contains",
      "severity": "medium",
      "category": "网络安全",
      "compliance": "GJB 5621A-2017-网络安全"
    },
    {
      "id": "GJB-5621A-034",
      "name": "安全策略-安全配置文件",
      "description": "检查安全配置文件",
      "command": "ls -la /etc/security/*.conf 2>/dev/null | head -5",
      "expected": "",
      "check_type": "not_empty",
      "severity": "low",
      "category": "安全策略",
      "compliance": "GJB 5621A-2017-安全管理"
    },
    {
      "id": "GJB-5621A-035",
      "name": "应急响应-备份验证",
      "description": "检查备份文件状态",
      "command": "ls -la /var/backups/*.bak 2>/dev/null || ls -la /backup/*.bak 2>/dev/null | head -5",
      "expected": "",
      "check_type": "not_empty",
      "severity": "high",
      "category": "应急响应",
      "compliance": "GJB 5621A-2017-应急响应"
    }
  ]
}
