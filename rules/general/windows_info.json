{
  "name": "Windows系统信息采集规则库",
  "version": "1.0.0",
  "description": "通用规则库 - 采集Windows目标对象的系统信息、硬件信息、网络配置等",
  "compliance": ["通用信息采集"],
  "rules": [
    {
      "id": "INFO-WIN-001",
      "name": "系统版本信息",
      "description": "采集Windows操作系统版本信息",
      "command": "systeminfo | findstr /B /C:\"OS\"",
      "expected": "",
      "check_type": "not_empty",
      "severity": "info",
      "category": "系统信息",
      "compliance": "信息采集"
    },
    {
      "id": "INFO-WIN-002",
      "name": "主机名",
      "description": "采集主机名",
      "command": "hostname",
      "expected": "",
      "check_type": "not_empty",
      "severity": "info",
      "category": "系统信息",
      "compliance": "信息采集"
    },
    {
      "id": "INFO-WIN-003",
      "name": "系统运行时间",
      "description": "采集系统运行时间",
      "command": "systeminfo | findstr \"System Boot Time\"",
