    {
      "id": "INFO-DB-015",
      "name": "二进制日志配置",
      "description": "采集二进制日志配置",
      "sql": "SHOW VARIABLES LIKE 'log_bin%';",
      "expected": "",
      "check_type": "not_empty",
      "severity": "info",
      "category": "日志配置",
      "compliance": "信息采集"
