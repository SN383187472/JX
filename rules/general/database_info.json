      "expected": "",
      "check_type": "not_empty",
      "severity": "info",
      "category": "连接信息",
      "compliance": "信息采集"
    },
    {
      "id": "INFO-DB-012",
      "name": "用户权限列表",
      "description": "采集用户权限列表",
      "sql": "SELECT user,host,Select_priv,Insert_priv,Update_priv,Delete_priv,Create_priv,Drop_priv,Grant_priv FROM mysql.user;",
      "expected": "",
      "check_type": "not_empty",
      "severity": "info",
      "category": "权限信息",
      "compliance": "信息采集"
