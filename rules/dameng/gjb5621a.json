{
  "name": "GJB 5621A 达梦数据库安全基线",
  "version": "1.0.0",
  "description": "符合GJB 5621A-2017军用软件安全需求分析指南的达梦数据库安全基线检查",
  "compliance": ["GJB 5621A-2017"],
  "category": "军用软件安全",
  "rules": [
    {
      "id": "GJB-DM-001",
      "name": "保密性-密码加密存储",
      "description": "检查用户密码是否使用强加密存储",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='PWD_POLICY';",
      "expected": "PWD_POLICY",
      "check_type": "contains",
      "severity": "high",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-DM-002",
      "name": "保密性-数据传输加密",
      "description": "检查是否启用通信加密",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='ENABLE_ENCRYPT';",
      "expected": "1",
      "check_type": "contains",
      "severity": "high",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-DM-003",
      "name": "保密性-敏感数据加密",
      "description": "检查是否配置加密算法",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME LIKE '%CRYPTO%';",
      "expected": "CRYPTO",
      "check_type": "contains",
      "severity": "medium",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-DM-004",
      "name": "完整性-审计功能开启",
      "description": "检查是否开启审计功能",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='AUDIT_FILE_PATH';",
      "expected": "AUDIT_FILE_PATH",
      "check_type": "contains",
      "severity": "high",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-DM-005",
      "name": "完整性-数据校验",
      "description": "检查数据完整性校验配置",
      "command": "grep 'CHECK_INTERVAL' /dm8/data/*/dm.ini 2>/dev/null || echo 'not configured'",
      "expected": "CHECK_INTERVAL",
      "check_type": "contains",
      "severity": "medium",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-DM-006",
      "name": "完整性-归档模式",
      "description": "检查是否启用归档模式",
      "sql": "SELECT ARCH_MODE FROM V$DATABASE;",
      "expected": "Y",
      "check_type": "contains",
      "severity": "high",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-DM-007",
      "name": "可用性-最大会话数",
      "description": "检查最大会话数配置",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='MAX_SESSIONS';",
      "expected": "MAX_SESSIONS",
      "check_type": "contains",
      "severity": "medium",
      "category": "可用性",
      "compliance": "GJB 5621A-2017-可用性"
    },
    {
      "id": "GJB-DM-008",
      "name": "可用性-会话超时",
      "description": "检查会话超时配置",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='IDLE_TIMEOUT';",
      "expected": "IDLE_TIMEOUT",
      "check_type": "contains",
      "severity": "medium",
      "category": "可用性",
      "compliance": "GJB 5621A-2017-可用性"
    },
    {
      "id": "GJB-DM-009",
      "name": "抗抵赖性-操作审计",
      "description": "检查是否记录操作审计",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='AUDIT_MODE';",
      "expected": "AUDIT_MODE",
      "check_type": "contains",
      "severity": "high",
      "category": "抗抵赖性",
      "compliance": "GJB 5621A-2017-抗抵赖性"
    },
    {
      "id": "GJB-DM-010",
      "name": "抗抵赖性-审计日志保留",
      "description": "检查审计日志保留配置",
      "command": "ls -la /dm8/log/*.log 2>/dev/null || ls -la /opt/dmdbms/log/*.log 2>/dev/null",
      "expected": ".log",
      "check_type": "contains",
      "severity": "medium",
      "category": "抗抵赖性",
      "compliance": "GJB 5621A-2017-抗抵赖性"
    },
    {
      "id": "GJB-DM-011",
      "name": "身份鉴别-密码复杂度",
      "description": "检查密码复杂度策略",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='PWD_POLICY';",
      "expected": "PWD_POLICY",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别",
      "compliance": "GJB 5621A-2017-身份鉴别"
    },
    {
      "id": "GJB-DM-012",
      "name": "身份鉴别-密码有效期",
      "description": "检查密码有效期配置",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='PWD_EXPIRE_TIME';",
      "expected": "PWD_EXPIRE_TIME",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别",
      "compliance": "GJB 5621A-2017-身份鉴别"
    },
    {
      "id": "GJB-DM-013",
      "name": "身份鉴别-登录失败锁定",
      "description": "检查登录失败锁定策略",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='LOGIN_FAIL_LOCK';",
      "expected": "LOGIN_FAIL_LOCK",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别",
      "compliance": "GJB 5621A-2017-身份鉴别"
    },
    {
      "id": "GJB-DM-014",
      "name": "访问控制-默认账户检查",
      "description": "检查默认账户状态",
      "sql": "SELECT USERNAME, ACCOUNT_STATUS FROM DBA_USERS WHERE USERNAME IN ('SYSDBA','SYSAUDITOR','SYSSSO');",
      "expected": "",
      "check_type": "not_empty",
      "severity": "medium",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-DM-015",
      "name": "访问控制-用户权限检查",
      "description": "检查用户权限分配",
      "sql": "SELECT GRANTEE, PRIVILEGE FROM DBA_SYS_PRIVS WHERE PRIVILEGE IN ('CREATE USER','DROP USER','GRANT ANY ROLE');",
      "expected": "",
      "check_type": "not_empty",
      "severity": "medium",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-DM-016",
      "name": "访问控制-PUBLIC角色权限",
      "description": "检查PUBLIC角色权限",
      "sql": "SELECT * FROM DBA_TAB_PRIVS WHERE GRANTEE='PUBLIC';",
      "expected": "",
      "check_type": "equals",
      "severity": "high",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-DM-017",
      "name": "安全审计-审计日志权限",
      "description": "检查审计日志文件权限",
      "command": "ls -la /dm8/log/ 2>/dev/null || ls -la /opt/dmdbms/log/ 2>/dev/null",
      "expected": "drwx",
      "check_type": "contains",
      "severity": "medium",
      "category": "安全审计",
      "compliance": "GJB 5621A-2017-安全审计"
    },
    {
      "id": "GJB-DM-018",
      "name": "安全审计-特权用户审计",
      "description": "检查是否审计特权操作",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='AUDIT_SYS_OPERATIONS';",
      "expected": "AUDIT_SYS_OPERATIONS",
      "check_type": "contains",
      "severity": "medium",
      "category": "安全审计",
      "compliance": "GJB 5621A-2017-安全审计"
    },
    {
      "id": "GJB-DM-019",
      "name": "网络安全-端口访问控制",
      "description": "检查端口访问控制配置",
      "command": "netstat -tuln | grep 5236",
      "expected": "5236",
      "check_type": "contains",
      "severity": "high",
      "category": "网络安全",
      "compliance": "GJB 5621A-2017-网络安全"
    },
    {
      "id": "GJB-DM-020",
      "name": "网络安全-IP访问限制",
      "description": "检查IP访问限制配置",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='ALLOW_IP';",
      "expected": "ALLOW_IP",
      "check_type": "contains",
      "severity": "medium",
      "category": "网络安全",
      "compliance": "GJB 5621A-2017-网络安全"
    },
    {
      "id": "GJB-DM-021",
      "name": "数据安全-数据目录权限",
      "description": "检查数据目录权限",
      "command": "ls -ld /dm8/data 2>/dev/null || ls -ld /opt/dmdbms/data 2>/dev/null",
      "expected": "drwx",
      "check_type": "contains",
      "severity": "high",
      "category": "数据安全",
      "compliance": "GJB 5621A-2017-数据安全"
    },
    {
      "id": "GJB-DM-022",
      "name": "数据安全-运行用户检查",
      "description": "检查是否使用专用用户运行",
      "command": "ps -ef | grep dmserver | grep -v grep | awk '{print $1}'",
      "expected": "dmdba",
      "check_type": "contains",
      "severity": "medium",
      "category": "数据安全",
      "compliance": "GJB 5621A-2017-数据安全"
    },
    {
      "id": "GJB-DM-023",
      "name": "备份恢复-备份目录检查",
      "description": "检查备份目录是否存在",
      "command": "ls -ld /dm8/bak 2>/dev/null || ls -ld /opt/dmdbms/bak 2>/dev/null || echo 'not found'",
      "expected": "bak",
      "check_type": "contains",
      "severity": "high",
      "category": "备份恢复",
      "compliance": "GJB 5621A-2017-备份恢复"
    },
    {
      "id": "GJB-DM-024",
      "name": "备份恢复-定期备份检查",
      "description": "检查是否有备份文件",
      "command": "ls -la /dm8/bak/*.bak 2>/dev/null || ls -la /opt/dmdbms/bak/*.bak 2>/dev/null || echo 'not found'",
      "expected": ".bak",
      "check_type": "contains",
      "severity": "high",
      "category": "备份恢复",
      "compliance": "GJB 5621A-2017-备份恢复"
    },
    {
      "id": "GJB-DM-025",
      "name": "资源控制-内存使用限制",
      "description": "检查内存使用限制配置",
      "sql": "SELECT * FROM V$PARAMETER WHERE NAME='MEMORY_POOL';",
      "expected": "MEMORY_POOL",
      "check_type": "contains",
      "severity": "medium",
      "category": "资源控制",
      "compliance": "GJB 5621A-2017-资源控制"
    }
  ]
}
