{
  "name": "GJB 5621A MySQL数据库安全基线",
  "version": "1.0.0",
  "description": "符合GJB 5621A-2017军用软件安全需求分析指南的MySQL数据库安全基线检查",
  "compliance": ["GJB 5621A-2017"],
  "category": "军用软件安全",
  "rules": [
    {
      "id": "GJB-MYSQL-001",
      "name": "保密性-密码加密存储",
      "description": "检查用户密码是否使用强加密存储",
      "sql": "SELECT plugin FROM mysql.user WHERE user='root' LIMIT 1;",
      "expected": "mysql_native_password",
      "check_type": "contains",
      "severity": "high",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-MYSQL-002",
      "name": "保密性-数据传输加密",
      "description": "检查是否启用SSL加密连接",
      "sql": "SHOW VARIABLES LIKE 'have_ssl';",
      "expected": "YES",
      "check_type": "contains",
      "severity": "high",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-MYSQL-003",
      "name": "保密性-敏感数据加密",
      "description": "检查是否有加密函数可用",
      "sql": "SHOW STATUS LIKE 'SSL%';",
      "expected": "SSL",
      "check_type": "contains",
      "severity": "medium",
      "category": "保密性",
      "compliance": "GJB 5621A-2017-保密性"
    },
    {
      "id": "GJB-MYSQL-004",
      "name": "完整性-审计日志开启",
      "description": "检查是否开启审计日志",
      "sql": "SHOW VARIABLES LIKE 'general_log';",
      "expected": "ON",
      "check_type": "contains",
      "severity": "high",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-MYSQL-005",
      "name": "完整性-二进制日志开启",
      "description": "检查是否开启二进制日志用于数据恢复",
      "sql": "SHOW VARIABLES LIKE 'log_bin';",
      "expected": "ON",
      "check_type": "contains",
      "severity": "high",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-MYSQL-006",
      "name": "完整性-错误日志记录",
      "description": "检查错误日志是否配置",
      "sql": "SHOW VARIABLES LIKE 'log_error';",
      "expected": ".err",
      "check_type": "contains",
      "severity": "medium",
      "category": "完整性",
      "compliance": "GJB 5621A-2017-完整性"
    },
    {
      "id": "GJB-MYSQL-007",
      "name": "可用性-最大连接数配置",
      "description": "检查最大连接数是否合理配置",
      "sql": "SHOW VARIABLES LIKE 'max_connections';",
      "expected": "max_connections",
      "check_type": "contains",
      "severity": "medium",
      "category": "可用性",
      "compliance": "GJB 5621A-2017-可用性"
    },
    {
      "id": "GJB-MYSQL-008",
      "name": "可用性-连接超时配置",
      "description": "检查连接超时是否配置",
      "sql": "SHOW VARIABLES LIKE 'wait_timeout';",
      "expected": "wait_timeout",
      "check_type": "contains",
      "severity": "medium",
      "category": "可用性",
      "compliance": "GJB 5621A-2017-可用性"
    },
    {
      "id": "GJB-MYSQL-009",
      "name": "抗抵赖性-操作审计",
      "description": "检查是否记录用户操作",
      "sql": "SHOW VARIABLES LIKE 'log_raw';",
      "expected": "log_raw",
      "check_type": "contains",
      "severity": "high",
      "category": "抗抵赖性",
      "compliance": "GJB 5621A-2017-抗抵赖性"
    },
    {
      "id": "GJB-MYSQL-010",
      "name": "抗抵赖性-慢查询日志",
      "description": "检查慢查询日志是否开启",
      "sql": "SHOW VARIABLES LIKE 'slow_query_log';",
      "expected": "ON",
      "check_type": "contains",
      "severity": "medium",
      "category": "抗抵赖性",
      "compliance": "GJB 5621A-2017-抗抵赖性"
    },
    {
      "id": "GJB-MYSQL-011",
      "name": "身份鉴别-密码复杂度",
      "description": "检查密码复杂度策略",
      "sql": "SHOW VARIABLES LIKE 'validate_password%';",
      "expected": "validate_password",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别",
      "compliance": "GJB 5621A-2017-身份鉴别"
    },
    {
      "id": "GJB-MYSQL-012",
      "name": "身份鉴别-密码有效期",
      "description": "检查密码有效期策略",
      "sql": "SHOW VARIABLES LIKE 'default_password_lifetime';",
      "expected": "default_password_lifetime",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别",
      "compliance": "GJB 5621A-2017-身份鉴别"
    },
    {
      "id": "GJB-MYSQL-013",
      "name": "身份鉴别-登录失败锁定",
      "description": "检查登录失败锁定策略",
      "sql": "SHOW VARIABLES LIKE '%connection_control%';",
      "expected": "connection_control",
      "check_type": "contains",
      "severity": "high",
      "category": "身份鉴别",
      "compliance": "GJB 5621A-2017-身份鉴别"
    },
    {
      "id": "GJB-MYSQL-014",
      "name": "访问控制-空密码账户检查",
      "description": "检查是否存在空密码账户",
      "sql": "SELECT COUNT(*) FROM mysql.user WHERE authentication_string='' OR password IS NULL;",
      "expected": "0",
      "check_type": "equals",
      "severity": "high",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-MYSQL-015",
      "name": "访问控制-匿名用户检查",
      "description": "检查是否存在匿名用户",
      "sql": "SELECT COUNT(*) FROM mysql.user WHERE user='';",
      "expected": "0",
      "check_type": "equals",
      "severity": "high",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-MYSQL-016",
      "name": "访问控制-root远程登录检查",
      "description": "检查root是否允许远程登录",
      "sql": "SELECT COUNT(*) FROM mysql.user WHERE user='root' AND host NOT IN ('localhost', '127.0.0.1');",
      "expected": "0",
      "check_type": "equals",
      "severity": "high",
      "category": "访问控制",
      "compliance": "GJB 5621A-2017-访问控制"
    },
    {
      "id": "GJB-MYSQL-017",
      "name": "安全审计-审计日志权限",
      "description": "检查日志文件权限",
      "command": "ls -la /var/log/mysql/ 2>/dev/null || ls -la /var/lib/mysql/*.err 2>/dev/null",
      "expected": "mysql",
      "check_type": "contains",
      "severity": "medium",
      "category": "安全审计",
      "compliance": "GJB 5621A-2017-安全审计"
    },
    {
      "id": "GJB-MYSQL-018",
      "name": "安全审计-用户操作记录",
      "description": "检查用户表访问权限",
      "sql": "SELECT user,host FROM mysql.user WHERE Super_priv='Y';",
      "expected": "root",
      "check_type": "contains",
      "severity": "medium",
      "category": "安全审计",
      "compliance": "GJB 5621A-2017-安全审计"
    },
    {
      "id": "GJB-MYSQL-019",
      "name": "网络安全-绑定地址限制",
      "description": "检查是否限制绑定地址",
      "sql": "SHOW VARIABLES LIKE 'bind_address';",
      "expected": "bind_address",
      "check_type": "contains",
      "severity": "high",
      "category": "网络安全",
      "compliance": "GJB 5621A-2017-网络安全"
    },
    {
      "id": "GJB-MYSQL-020",
      "name": "网络安全-禁止本地文件加载",
      "description": "检查是否禁止LOAD DATA LOCAL",
      "sql": "SHOW VARIABLES LIKE 'local_infile';",
      "expected": "OFF",
      "check_type": "contains",
      "severity": "medium",
      "category": "网络安全",
      "compliance": "GJB 5621A-2017-网络安全"
    },
    {
      "id": "GJB-MYSQL-021",
      "name": "数据安全-数据目录权限",
      "description": "检查数据目录权限",
      "command": "ls -ld /var/lib/mysql 2>/dev/null",
      "expected": "drwx",
      "check_type": "contains",
      "severity": "high",
      "category": "数据安全",
      "compliance": "GJB 5621A-2017-数据安全"
    },
    {
      "id": "GJB-MYSQL-022",
      "name": "数据安全-运行用户检查",
      "description": "检查是否使用专用用户运行",
      "command": "ps -ef | grep mysqld | grep -v grep | awk '{print $1}'",
      "expected": "mysql",
      "check_type": "contains",
      "severity": "medium",
      "category": "数据安全",
      "compliance": "GJB 5621A-2017-数据安全"
    },
    {
      "id": "GJB-MYSQL-023",
      "name": "备份恢复-二进制日志格式",
      "description": "检查二进制日志格式",
      "sql": "SHOW VARIABLES LIKE 'binlog_format';",
      "expected": "ROW",
      "check_type": "contains",
      "severity": "medium",
      "category": "备份恢复",
      "compliance": "GJB 5621A-2017-备份恢复"
    },
    {
      "id": "GJB-MYSQL-024",
      "name": "备份恢复-同步复制检查",
      "description": "检查是否配置同步复制",
      "sql": "SHOW VARIABLES LIKE 'sync_binlog';",
      "expected": "sync_binlog",
      "check_type": "contains",
      "severity": "medium",
      "category": "备份恢复",
      "compliance": "GJB 5621A-2017-备份恢复"
    },
    {
      "id": "GJB-MYSQL-025",
      "name": "资源控制-最大错误连接数",
      "description": "检查最大连接错误数配置",
      "sql": "SHOW VARIABLES LIKE 'max_connect_errors';",
      "expected": "max_connect_errors",
      "check_type": "contains",
      "severity": "medium",
      "category": "资源控制",
      "compliance": "GJB 5621A-2017-资源控制"
    }
  ]
}
